# Copy to .env and adjust. The CLI reads FIFOS_WEBHOOK from the project directory.

# Webhook URL for `fifos` CLI (per-project — points at one fifo)
# FIFOS_WEBHOOK=https://fifos.in/w/01XXXXXXXXXXXXXXXXXXXXXXXX

# --- Server (optional) ---
# PORT=3000
# HOST=0.0.0.0

# Public base URL (CLI prepends this when given a bare ULID via -f)
# FIFOS_DOMAIN=http://localhost:3000

# SQLite database path (self-host)
# FIFOS_DB_PATH=data/fifos.db

# Session cookies — required in hosted / Legendum mode
# FIFOS_COOKIE_SECRET=

# Queue tuning
# FIFOS_LOCK_TIMEOUT_SECONDS=300         # default lock TTL on pull (5 min)
# FIFOS_RETENTION_SECONDS=604800         # done/fail retention (7 days)
# FIFOS_PURGE_INTERVAL_SECONDS=3600      # time-based sweep cadence (1h)
# FIFOS_MAX_ITEMS_PER_FIFO=10000
# FIFOS_MAX_ITEM_BYTES=65536
# FIFOS_MAX_FIFOS_PER_USER=50

# --- Legendum (hosted mode) ---
# Setting LEGENDUM_API_KEY enables hosted mode (login + billing).
# LEGENDUM_API_KEY=
# LEGENDUM_SECRET=
# LEGENDUM_BASE_URL=https://legendum.co.uk
